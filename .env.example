# API Configuration for Campus Map Mobile App
# Copy this file to .env and update the values

# URL of the web-admin API
# For local development, use your computer's IP address or localhost
# For production, use your deployed web-admin URL
EXPO_PUBLIC_API_URL=http://localhost:3000

# Supabase Configuration (for direct database access)
# Get these from your Supabase project settings
EXPO_PUBLIC_SUPABASE_URL=your-supabase-url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
